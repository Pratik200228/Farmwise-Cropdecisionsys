# FarmWise AI - Environment Configuration TEMPLATE
#
# Copy this file to backend/.env (NOT root .env) and fill in the keys you have.
# python-dotenv is loaded by backend/app/main.py on startup.
#
# The chat works without any keys (rule-based dispatcher with 19 intents);
# adding an LLM key upgrades it to Claude / GPT for free-form questions.

# ---- LLM provider selection ------------------------------------------------
# anthropic | openai | groq | gemini
LLM_PROVIDER=groq

# ---- Groq (free tier, OpenAI-compatible) -----------------------------------
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Anthropic (Claude) ----------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ---- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ---- Google Gemini ---------------------------------------------------------
# Get a key from Google AI Studio.
GEMINI_API_KEY=your_gemini_key_here
# Examples: gemini-1.5-flash, gemini-1.5-pro (depends on your account access)
GEMINI_MODEL=gemini-1.5-flash

# ---- Optional integrations -------------------------------------------------
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here
USDA_API_KEY=your_usda_api_key_here
PLANT_HEALTH_API_KEY=your_plant_health_key_here

# ---- App config ------------------------------------------------------------
APP_ENV=development
DEBUG=True
HOST=0.0.0.0
PORT=8000
