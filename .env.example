# FarmWise AI - Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenWeatherMap API (weather data)
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# USDA API (market price data)
USDA_API_KEY=your_usda_api_key_here

# LLM API for Crop Suitability Agent
# Use either OpenAI or Anthropic
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
LLM_PROVIDER=anthropic  # or "openai"

# PlantVillage / Crop Health API
PLANT_HEALTH_API_KEY=your_plant_health_key_here

# Server Config
HOST=0.0.0.0
PORT=8000
DEBUG=true
